<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pizza Virus</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #000;
        }
        .pizza {
            position: absolute;
            font-size: 40px;
            user-select: none;
            pointer-events: none;
        }
    </style>
</head>
<body>
    <script>
        function crearPizza() {
            const pizza = document.createElement('div');
            pizza.className = 'pizza PIZA PIZZZAAAAA';
            pizza.textContent = '🍕';
            pizza.style.left = Math.random() * window.innerWidth + 'px';
            pizza.style.top = Math.random() * window.innerHeight + 'px';
            document.body.appendChild(pizza);
        }

        // Generar una pizza cada 10ms
        setInterval(crearPizza, 10);
    </script>
</body>
</html>